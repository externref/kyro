var io = use("std:io");

class Animal {
    init(){
        io.println("new animal");
    }
    do_sound(){
        io.println("generic animal sound");
    }
}

class Cat < Animal {
    init(name){
        super.init();
        this.name = name;
    }
    do_sound(){
        io.println("${this.name} says meow");
    }
}

fn main(){
    var cat = Cat("bob");
    cat.do_sound();
}

main();

