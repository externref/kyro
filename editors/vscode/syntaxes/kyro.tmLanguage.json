{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "kyro",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#numbers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.kyro",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.kyro",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.kyro",
              "match": "\\\\."
            },
            {
              "name": "meta.embedded.line.kyro",
              "begin": "\\$\\{",
              "end": "\\}",
              "patterns": [
                {
                  "include": "source.kyro"
                }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.single.kyro",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.kyro",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.kyro",
          "match": "\\b(echo|return|try|catch|throw|if|else|while|for|and|or)\\b"
        },
        {
          "name": "storage.type.kyro",
          "match": "\\b(fn|class|var)\\b"
        },
        {
          "name": "variable.language.kyro",
          "match": "\\b(this|super)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.kyro",
          "match": "\\b(true|false|nil)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.kyro",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    }
  },
  "scopeName": "source.kyro"
}